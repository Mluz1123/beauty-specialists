---
import { siteConfig } from '../data/config';
---

<section
  id="nosotros"
  class="py-24 overflow-hidden"
  aria-labelledby="about-heading"
>
  <div class="max-w-7xl mx-auto px-6">
    <div class="grid md:grid-cols-2 gap-16 items-center">

      <!-- Left: Portrait -->
      <div class="reveal relative">
        <!-- Decorative accent frame -->
        <div
          class="absolute -bottom-4 -right-4 w-full h-full rounded-2xl"
          style="border: 1px solid rgba(232,168,154,0.25);"
          aria-hidden="true"
        ></div>
        <div
          class="absolute -bottom-8 -right-8 w-3/4 h-3/4 rounded-2xl"
          style="border: 1px solid rgba(232,168,154,0.12);"
          aria-hidden="true"
        ></div>

        <!-- Portrait image -->
        <div class="relative rounded-2xl overflow-hidden" style="border: 1px solid #3A3A3A;">
          <img
            src="/img/about_portrait.png"
            alt="Erika Bello — Maquilladora profesional y estilista Beauty Specialists"
            class="w-full object-cover"
            width="600"
            height="700"
            loading="lazy"
          />
          <!-- Subtle overlay -->
          <div
            class="absolute inset-0"
            style="background: linear-gradient(to top, rgba(26,26,26,0.6) 0%, transparent 50%);"
            aria-hidden="true"
          ></div>
          <!-- Name tag -->
          <div class="absolute bottom-5 left-5 right-5">
            <span
              style="font-family: var(--font-script);"
              class="block text-3xl text-accent leading-none"
            >
              Erika Bello
            </span>
            <span class="text-xs text-white/60 tracking-widest uppercase">
              Maquilladora Profesional
            </span>
          </div>
        </div>

        <!-- Decorative script background -->
        <span
          class="absolute text-8xl font-bold text-white/[0.025] select-none pointer-events-none -z-10"
          style="font-family: var(--font-script); bottom: -1.5rem; left: -1rem;"
          aria-hidden="true"
        >
          Beauty
        </span>
      </div>

      <!-- Right: Content -->
      <div class="reveal stagger-2">
        <span class="section-label" aria-hidden="true">Nuestra historia</span>
        <h2 id="about-heading" class="section-title mb-4">
          Sobre<br />
          <em
            style="font-family: var(--font-heading);"
            class="font-normal text-accent not-italic"
          >
            Beauty Specialists
          </em>
        </h2>
        <div class="section-divider"></div>

        <p class="text-text-muted leading-relaxed mb-6">
          Somos un estudio de belleza especializado en realzar la belleza natural de cada mujer
          en sus momentos más especiales. Con años de experiencia en el mundo del maquillaje
          artístico y profesional, Erika Bello lidera un equipo apasionado por crear looks
          únicos y personalizados.
        </p>
        <p class="text-text-muted leading-relaxed mb-8">
          Nuestra especialidad son las novias, quinceañeras y eventos sociales. Cada servicio
          incluye una preparación de piel con tecnología de punta — máscaras LED, esferas de
          hielo y mascarilla hidroplástica — para garantizar un maquillaje impecable que dure
          toda la celebración.
        </p>

        <!-- Stats -->
        <div class="grid grid-cols-3 gap-6 mb-8 pt-4 border-t border-border">
          <div class="text-center">
            <span
              style="font-family: var(--font-heading);"
              class="block text-3xl font-bold text-accent"
            >
              500+
            </span>
            <span class="text-xs text-text-muted uppercase tracking-wider">Novias</span>
          </div>
          <div class="text-center">
            <span
              style="font-family: var(--font-heading);"
              class="block text-3xl font-bold text-accent"
            >
              5★
            </span>
            <span class="text-xs text-text-muted uppercase tracking-wider">Calificación</span>
          </div>
          <div class="text-center">
            <span
              style="font-family: var(--font-heading);"
              class="block text-3xl font-bold text-accent"
            >
              8+
            </span>
            <span class="text-xs text-text-muted uppercase tracking-wider">Años</span>
          </div>
        </div>

        <a
          href={`https://wa.me/${siteConfig.contact.whatsapp}?text=Hola,%20quiero%20saber%20m%C3%A1s%20sobre%20sus%20servicios`}
          target="_blank"
          rel="noopener noreferrer"
          class="btn-primary"
        >
          Contáctanos
        </a>
      </div>
    </div>
  </div>
</section>
