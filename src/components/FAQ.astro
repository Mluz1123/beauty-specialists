---
import { faqItems } from '../data/faq';
---

<section
  id="faq"
  class="py-24"
  style="background-color: #1A1A1A;"
  aria-labelledby="faq-heading"
>
  <div class="max-w-3xl mx-auto px-6">

    <!-- Heading -->
    <div class="text-center mb-16 reveal">
      <span class="section-label" aria-hidden="true">Resolvemos tus dudas</span>
      <h2 id="faq-heading" class="section-title">
        Preguntas Frecuentes
      </h2>
      <div class="section-divider mx-auto"></div>
    </div>

    <!-- Accordion -->
    <div class="space-y-3" role="list">
      {faqItems.map((item, i) => (
        <div
          class={`reveal stagger-${i + 1} faq-item rounded-xl overflow-hidden`}
          style="background-color: #2B2B2B; border: 1px solid #3A3A3A;"
          role="listitem"
        >
          <button
            class="faq-trigger w-full text-left px-6 py-5 flex items-center justify-between gap-4 group"
            aria-expanded="false"
            aria-controls={`faq-answer-${item.id}`}
            id={`faq-trigger-${item.id}`}
          >
            <span
              style="font-family: var(--font-heading);"
              class="text-base font-semibold text-white group-hover:text-accent transition-colors duration-200"
            >
              {item.question}
            </span>
            <span
              class="faq-icon flex-shrink-0 w-7 h-7 rounded-full flex items-center justify-center transition-all duration-300"
              style="background: rgba(232,168,154,0.12); border: 1px solid rgba(232,168,154,0.2);"
              aria-hidden="true"
            >
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="#E8A89A" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="6 9 12 15 18 9"/>
              </svg>
            </span>
          </button>

          <div
            class="faq-answer overflow-hidden"
            id={`faq-answer-${item.id}`}
            role="region"
            aria-labelledby={`faq-trigger-${item.id}`}
            style="max-height: 0;"
          >
            <div class="px-6 pb-5">
              <p class="text-sm text-text-muted leading-relaxed">
                {item.answer}
              </p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <!-- Footer note -->
    <p class="text-center text-sm text-text-muted mt-10 reveal">
      ¿Tienes más preguntas?{' '}
      <a
        href="https://wa.me/573133640112?text=Hola,%20tengo%20una%20pregunta"
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent hover:underline"
      >
        Escríbenos por WhatsApp
      </a>
    </p>
  </div>
</section>

<style>
  .faq-item.open {
    border-color: rgba(232, 168, 154, 0.3);
  }
  .faq-item.open .faq-icon {
    transform: rotate(180deg);
    background: rgba(232,168,154,0.2);
  }
  .faq-answer {
    transition: max-height 0.35s cubic-bezier(0.4, 0, 0.2, 1);
  }
</style>

<script>
  document.querySelectorAll<HTMLButtonElement>('.faq-trigger').forEach((trigger) => {
    trigger.addEventListener('click', () => {
      const item = trigger.closest('.faq-item') as HTMLElement;
      const answer = item.querySelector('.faq-answer') as HTMLElement;
      const isOpen = item.classList.contains('open');

      // Close all open items
      document.querySelectorAll<HTMLElement>('.faq-item.open').forEach((openItem) => {
        openItem.classList.remove('open');
        const openAnswer = openItem.querySelector<HTMLElement>('.faq-answer')!;
        openAnswer.style.maxHeight = '0';
        openItem.querySelector<HTMLButtonElement>('.faq-trigger')!.setAttribute('aria-expanded', 'false');
      });

      // Open clicked (if it was closed)
      if (!isOpen) {
        item.classList.add('open');
        answer.style.maxHeight = answer.scrollHeight + 'px';
        trigger.setAttribute('aria-expanded', 'true');
      }
    });
  });
</script>
