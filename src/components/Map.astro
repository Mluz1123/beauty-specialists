---
import { siteConfig } from '../data/config';
---

<section
  id="ubicacion"
  class="py-24"
  style="background-color: #1E1E1E;"
  aria-labelledby="map-heading"
>
  <div class="max-w-7xl mx-auto px-6">

    <!-- Heading -->
    <div class="text-center mb-16 reveal">
      <span class="section-label" aria-hidden="true">Encuéntranos</span>
      <h2 id="map-heading" class="section-title">
        Ubicación
      </h2>
      <div class="section-divider mx-auto"></div>
    </div>

    <div class="grid md:grid-cols-2 gap-10 items-start">

      <!-- Map embed -->
      <div class="reveal rounded-xl overflow-hidden" style="border: 1px solid #3A3A3A;">
        <iframe
          src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d15909.232!2d-74.1067!3d4.8074!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x8e3f84f2f00b71f5%3A0x62b5a08c36a51c65!2sCota%2C+Cundinamarca!5e0!3m2!1ses!2sco!4v1700000000000"
          width="100%"
          height="400"
          style="border:0; display:block; filter: grayscale(30%) contrast(1.1);"
          allowfullscreen
          loading="lazy"
          referrerpolicy="no-referrer-when-downgrade"
          title="Mapa de ubicación de Beauty Specialists en Cota, Cundinamarca"
          aria-label="Mapa interactivo de Google Maps mostrando la ubicación del estudio"
        ></iframe>
      </div>

      <!-- Contact info -->
      <div class="reveal stagger-2 space-y-8">

        <!-- Address -->
        <div class="flex gap-5">
          <div
            class="w-12 h-12 rounded-full flex-shrink-0 flex items-center justify-center text-accent"
            style="background: rgba(232,168,154,0.1); border: 1px solid rgba(232,168,154,0.2);"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/>
              <circle cx="12" cy="10" r="3"/>
            </svg>
          </div>
          <div>
            <h3 style="font-family: var(--font-heading);" class="text-sm font-semibold text-white uppercase tracking-wider mb-1">Dirección</h3>
            <address class="not-italic text-text-muted text-sm leading-relaxed">
              {siteConfig.location.address}<br />
              {siteConfig.location.city}, {siteConfig.location.state}<br />
              {siteConfig.location.country}
            </address>
          </div>
        </div>

        <!-- Phone / WhatsApp -->
        <div class="flex gap-5">
          <div
            class="w-12 h-12 rounded-full flex-shrink-0 flex items-center justify-center text-accent"
            style="background: rgba(232,168,154,0.1); border: 1px solid rgba(232,168,154,0.2);"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 13a19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 3.62 2h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <div>
            <h3 style="font-family: var(--font-heading);" class="text-sm font-semibold text-white uppercase tracking-wider mb-1">Teléfono / WhatsApp</h3>
            <a
              href={`https://wa.me/${siteConfig.contact.whatsapp}`}
              class="text-text-muted text-sm hover:text-accent transition-colors duration-200"
              target="_blank"
              rel="noopener noreferrer"
            >
              {siteConfig.contact.phone}
            </a>
          </div>
        </div>

        <!-- Email -->
        <div class="flex gap-5">
          <div
            class="w-12 h-12 rounded-full flex-shrink-0 flex items-center justify-center text-accent"
            style="background: rgba(232,168,154,0.1); border: 1px solid rgba(232,168,154,0.2);"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <div>
            <h3 style="font-family: var(--font-heading);" class="text-sm font-semibold text-white uppercase tracking-wider mb-1">Email</h3>
            <a
              href={`mailto:${siteConfig.contact.email}`}
              class="text-text-muted text-sm hover:text-accent transition-colors duration-200"
              onclick="gtag('event','email_click',{event_category:'Contact'});"
            >
              {siteConfig.contact.email}
            </a>
          </div>
        </div>

        <!-- Hours -->
        <div class="flex gap-5">
          <div
            class="w-12 h-12 rounded-full flex-shrink-0 flex items-center justify-center text-accent"
            style="background: rgba(232,168,154,0.1); border: 1px solid rgba(232,168,154,0.2);"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 16 14"/>
            </svg>
          </div>
          <div>
            <h3 style="font-family: var(--font-heading);" class="text-sm font-semibold text-white uppercase tracking-wider mb-1">Horarios</h3>
            <p class="text-text-muted text-sm">{siteConfig.schedule.weekdays}</p>
            <p class="text-text-muted text-sm">{siteConfig.schedule.sunday}</p>
          </div>
        </div>

        <!-- Social -->
        <div class="flex gap-4 pt-2">
          <a
            href={siteConfig.social.instagramUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-sm text-text-muted hover:text-accent transition-colors duration-200"
            aria-label="Instagram Beauty Specialists"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
            {siteConfig.social.handle}
          </a>
          <span class="text-border" aria-hidden="true">·</span>
          <a
            href={siteConfig.social.instagramNoviasUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="flex items-center gap-2 text-sm text-text-muted hover:text-accent transition-colors duration-200"
            aria-label="Instagram Beauty Specialists Novias"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <rect x="2" y="2" width="20" height="20" rx="5" ry="5"/>
              <path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"/>
              <line x1="17.5" y1="6.5" x2="17.51" y2="6.5"/>
            </svg>
            {siteConfig.social.handleNovias}
          </a>
        </div>
      </div>
    </div>
  </div>
</section>
